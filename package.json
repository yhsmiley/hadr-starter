{
  "name": "hadr-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "HADR Monitor -- fuses GDACS/USGS/ReliefWeb feeds into a daily sitrep.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
